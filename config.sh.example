#!/usr/bin/env bash
# Copy to config.sh (gitignored) and edit. Only MEETINGS_BASE + MODEL_SUMMARY are
# required; everything else has sane defaults baked into src/config.ts.

export MEETINGS_BASE="$HOME/Recordings/Meetings"
export MODEL_SUMMARY="gemma3:12b"               # any Ollama chat model. NOTE: *-mlx tags (e.g.
                                                # gemma4:26b-mlx) are custom LOCAL MLX builds, not
                                                # pullable — create them with `ollama create`.

# --- Daemon / ASR (optional) ---
# export MURMUR_PORT=7461                      # localhost control API port
# export PROCESS_TIMEOUT_SECONDS=7200          # per-stage wall-clock backstop (kills a wedged ASR/ollama job)
# export ASR_MODEL="mlx-community/whisper-large-v3-turbo"   # mlx-whisper model (hf repo)
# export ASR_LANG="auto"                       # auto-detect per recording; set "cs"/"en"/… to force.
#                                              # Forcing a language drops speech in OTHER languages —
#                                              # leave on auto for bilingual (e.g. cs+en) meetings.
# export MURMUR_PYTHON="$HOME/.local/share/murmur/asr-venv/bin/python"   # asr venv python (default)

# --- Summarization (optional) ---
# export OLLAMA_HOST="http://localhost:11434"  # ollama server (set if remote or non-default port)
# export PROMPT_FILE="$PWD/prompts/summary.md" # summary prompt (default: repo prompts/summary.md,
#                                              # which instructs Czech output — point elsewhere to
#                                              # change the summary language/style)

# --- Diarization (speaker labels, optional, OFF by default) ---
# Requires a HuggingFace token + accepting the community-1 model terms. The ASR venv
# (see README → Install) already has pyannote.audio — no separate environment.
# export DIARIZE=1
# export HF_TOKEN="hf_xxx"
# Or feed the secret to the launchd daemon (no shell env) without storing it here:
#   [ -f "$HOME/.zsh/env/.secrets-cache" ] && source "$HOME/.zsh/env/.secrets-cache"
# export DIARIZE_NUM_SPEAKERS=0                 # speaker-count hint; 0 = auto-detect

# --- Obsidian vault archiving (optional, OFF unless OBSIDIAN_VAULT is set) ---
# Copies each finished summary into the vault as
#   <VAULT_FOLDER>/<YYYY-MM>/<YYYY-MM-DD HH-MM> <generated title>.md  (with YAML frontmatter).
# Originals stay in $MEETINGS_BASE; the vault is a derived copy.
# export OBSIDIAN_VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/<Vault>"
# export VAULT_FOLDER="Murmur"

# --- Recording (optional) ---
# Backend (see README → Recording backends):
#   ownscribe — system tap + mic, host-time-synced, keeps volume keys (recommended)
#   ffmpeg    — one avfoundation Aggregate Device (default; needs a BlackHole multi-output)
# export RECORD_BACKEND=ownscribe
# export MAX_DURATION_SECONDS=7200             # 2h hard cap
# export RECORD_SILENCE_DB=-80                 # warn on stop if a track's peak dBFS is at/below this
#
# --- ownscribe backend ---
# export OWNSCRIBE_BIN="$HOME/.local/bin/ownscribe-audio"   # build: see README → Recording backends
#
# --- ffmpeg backend ---
# avfoundation index of your Aggregate Device. Find it: ffmpeg -f avfoundation -list_devices true -i ""
# export RECORD_DEVICE_INDEX=0
# Downmix to mono. Default layout: c0+c1 = BlackHole (system audio), c2 = mic.
# Override if your Aggregate Device orders its sub-devices differently (a wrong map = mute capture).
# export RECORD_PAN_FILTER="pan=mono|c0=0.35*c0+0.35*c1+0.7*c2,alimiter"

# --- Auto-record (planned; NOT wired up yet — these have NO effect today) ---
# export AUTORECORD=0
# export MEETING_APPS="zoom.us,Microsoft Teams,Google Chrome"
