#!/usr/bin/env bash
# Copy to config.sh (gitignored) and edit. Only MEETINGS_BASE + MODEL_SUMMARY are
# required; everything else has sane defaults baked into src/config.ts.

export MEETINGS_BASE="$HOME/Recordings/Meetings"
export MODEL_SUMMARY="gemma4:26b-mlx"

# --- Daemon / whisply (optional) ---
# export MEETING_AI_PORT=7461                  # localhost control API port
# export WHISPLY_BIN="$HOME/.local/bin/whisply"
# export WHISPLY_MODEL="large-v3-turbo"
# export WHISPLY_LANG="cs"                     # keep set so output filenames are deterministic
# export WHISPLY_DEVICE="mlx"                  # mlx | gpu | cpu | auto

# --- Diarization (optional, OFF by default) ---
# Requires a HuggingFace token AND accepting the pyannote model terms:
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-3.1
# export DIARIZE=1
# export HF_TOKEN="hf_xxx"
# Or, to feed a secret to the launchd daemon (which has no shell env) without storing
# it here in plaintext, source your secrets file/manager from config.sh, e.g.:
#   [ -f "$HOME/.zsh/env/.secrets-cache" ] && source "$HOME/.zsh/env/.secrets-cache"

# --- Obsidian vault archiving (optional, OFF unless OBSIDIAN_VAULT is set) ---
# Copies each finished summary into the vault as
#   <VAULT_FOLDER>/<YYYY-MM>/<YYYY-MM-DD HH-MM> <generated title>.md  (with YAML frontmatter).
# Originals stay in $MEETINGS_BASE; the vault is a derived copy.
# export OBSIDIAN_VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/<Vault>"
# export VAULT_FOLDER="Murmur"

# --- Recording (optional) ---
# avfoundation index of your Aggregate Device, used when the daemon/SwiftBar start
# recording. Find it with: ffmpeg -f avfoundation -list_devices true -i ""
# Backend: "ffmpeg" (default; one avfoundation Aggregate Device) or "audiotee"
# (system-audio Core Audio tap + separate mic, mixed on stop — see README → Recording backends).
# export RECORD_BACKEND=ffmpeg
# export MAX_DURATION_SECONDS=7200             # 2h hard cap
# export RECORD_SILENCE_DB=-80                 # warn on stop if a track's peak dBFS is at/below this
#
# --- ffmpeg backend ---
# export RECORD_DEVICE_INDEX=0
# Downmix to mono. Default layout: c0+c1 = BlackHole (system audio), c2 = mic.
# Override if your Aggregate Device orders its sub-devices differently (a wrong map = mute capture).
# export RECORD_PAN_FILTER="pan=mono|c0=0.35*c0+0.35*c1+0.7*c2,alimiter"
#
# --- audiotee backend ---
# export AUDIOTEE_BIN="$HOME/.local/bin/audiotee"      # build: see README → Recording backends
# export RECORD_MIC_DEVICE="MacBook Pro Microphone"    # mic name or avfoundation index for your voice

# --- Auto-record (v2, not yet implemented) ---
# export AUTORECORD=0
# export MEETING_APPS="zoom.us,Microsoft Teams,Google Chrome"
